<!-- Canvas 2D（基础库 ≥2.9.0），同层渲染与性能优于旧接口 -->
<canvas wx:if="{{isUseNewCanvas}}" type="2d" id="{{ canvasId }}" class="ec-canvas" canvas-id="{{ canvasId }}" bindtouchstart="{{ ec.disableTouch ? '' : 'touchStart' }}" bindtouchmove="{{ ec.disableTouch ? '' : 'touchMove' }}" bindtouchend="{{ ec.disableTouch ? '' : 'touchEnd' }}"></canvas>
<!-- 旧版 canvas（仅低版本基础库回退） -->
<canvas wx:else class="ec-canvas" canvas-id="{{ canvasId }}" bindtouchstart="{{ ec.disableTouch ? '' : 'touchStart' }}" bindtouchmove="{{ ec.disableTouch ? '' : 'touchMove' }}" bindtouchend="{{ ec.disableTouch ? '' : 'touchEnd' }}"></canvas>
