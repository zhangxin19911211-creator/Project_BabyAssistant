/**app.wxss**/
page {
  /* 基础配色 */
  --primary-color: #81C784;
  --primary-light: rgba(129, 199, 132, 0.2);
  --secondary-color: #A5D6A7;
  --text-main: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #F7F7F8;
  --white: #FFFFFF;
  --success: #32CD32;
  --danger: #E85C5C;
  
  /* Call Me By Your Name 配色方案 */
  --cmbyn-color-1: #87CEEB;
  --cmbyn-color-2: #4682B4;
  --cmbyn-color-3: #FFDAB9;
  --cmbyn-color-4: #FFA07A;
  --cmbyn-color-5: #2E8B57;
  
  /* Categorical Data 配色方案 */
  --cat-color-1: #5470C6;
  --cat-color-2: #91CC75;
  --cat-color-3: #FAC858;
  --cat-color-4: #EE6666;
  --cat-color-5: #73C0DE;
  
  /* 优化后的色彩 */
  --baby-primary: #66C9A8;
  --baby-primary-light: #E0F5EF;
  --baby-primary-dark: #4DB896;
  --baby-coral: #FFA69E;
  --baby-coral-light: #FFE8E6;
  --baby-yellow: #FFD166;
  --baby-yellow-light: #FFF8E1;
  --baby-blue: #64B5F6;
  --baby-blue-light: #E3F2FD;
  --baby-bg: #FDF5F0;
  --baby-card: #FFFFFF;
  --baby-text: #2D2D2D;
  --baby-text-secondary: #5B6270;
  --baby-text-light: #8C939F;
  --baby-success: #5BCB67;
  --baby-warning: #FFC107;
  --baby-danger: #FF7B84;
  --baby-shadow: rgba(102, 209, 185, 0.2);

  background-color: var(--baby-bg);
  font-family: 'Alibaba PuHuiTi', 'PingFang SC', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  color: var(--baby-text);
  box-sizing: border-box;
}

/* 使用系统字体 */

page {
  font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 家庭配色方案 */
page {
  --family-color-0-primary: var(--cmbyn-color-1);
  --family-color-0-light: rgba(135, 206, 235, 0.1);
  --family-color-0-dark: var(--cmbyn-color-2);
  
  --family-color-1-primary: var(--cmbyn-color-3);
  --family-color-1-light: rgba(255, 218, 185, 0.1);
  --family-color-1-dark: var(--cmbyn-color-4);
  
  --family-color-2-primary: var(--cmbyn-color-5);
  --family-color-2-light: rgba(46, 139, 87, 0.1);
  --family-color-2-dark: #228B22;
}
