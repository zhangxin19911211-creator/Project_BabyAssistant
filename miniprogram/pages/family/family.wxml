<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-decoration"></view>
    <view class="user-info-row">
      <view class="user-avatar-large" catchtap="onHeaderAvatarTap">
        <image class="avatar-large" src="{{currentUser.avatarUrl || '../../images/avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-name-wrap" catchtap="onHeaderNameTap">
        <text class="user-name-large">{{currentUser.nickName || '用户'}}</text>
      </view>
    </view>
    <view class="user-roles-row">
      <view class="user-roles-list">
        <view wx:for="{{userFamilyRoles}}" wx:key="familyId" class="user-role-item {{item.permission}}">
          <text class="role-family-name">{{item.familyName}}</text>
          <text class="role-permission">{{item.permissionText}}</text>
        </view>
      </view>
    </view>
    <view class="header-actions">
      <button class="action-btn-small join-btn" bindtap="openJoinModal">
        <text class="btn-text">加入家庭</text>
      </button>
      <button class="action-btn-small create-btn" bindtap="openCreateModal">
        <text class="btn-text">新建家庭</text>
      </button>
    </view>
  </view>
  
  <!-- 家庭列表 -->
  <view class="families-section">
    <view wx:if="{{families.length === 0}}" class="empty-state">
      <!-- 装饰性背景元素 -->
      <view class="empty-bg-decoration bg-1"></view>
      <view class="empty-bg-decoration bg-2"></view>
      <view class="empty-bg-decoration bg-3"></view>
      
      <!-- 图标区域 -->
      <view class="empty-icon-container">
        <view class="icon-bg-circle"></view>
        <image class="empty-icon" src="../../images/family-empty.svg" mode="aspectFit"></image>
      </view>
      
      <!-- 文字区域 -->
      <view class="empty-text-area">
        <text class="empty-main-title">暂无家庭</text>
        <text class="empty-desc">创建或加入家庭，与家人一起关注宝宝成长</text>
      </view>
      
      <!-- 按钮区域 -->
      <view class="empty-action-btns">
        <button class="action-btn create-family-btn" bindtap="openCreateModal">
          <text class="btn-icon">+</text>
          <text class="btn-label">新建家庭</text>
        </button>
        <button class="action-btn join-family-btn" bindtap="openJoinModal">
          <text class="btn-icon">→</text>
          <text class="btn-label">加入家庭</text>
        </button>
      </view>
    </view>
    
    <view wx:else class="families-list">
      <view class="family-card color-{{item.colorIndex}}" wx:for="{{families}}" wx:key="_id">
        <view class="family-header color-{{item.colorIndex}}">
          <view class="family-info">
            <text class="family-name">我的家庭：{{item.name}}</text>
            <text class="family-member-count">{{item.members.length}} 位成员</text>
          </view>
          <view class="family-header-actions">
            <button class="action-btn-small edit-name-btn" bindtap="openEditNameModal" data-family-id="{{item._id}}">
              <text class="btn-text">修改名称</text>
            </button>
            <button class="action-btn-small leave-btn" bindtap="leaveFamily" data-family-id="{{item._id}}">
              <text class="btn-text">退出家庭</text>
            </button>
            <button class="action-btn-small invite-btn" bindtap="openInviteModal" data-family-id="{{item._id}}">
              <text class="btn-text">邀请成员</text>
            </button>
          </view>
        </view>
        
        <view class="members-list">
          <view class="member-card" wx:for="{{item.members}}" wx:key="openid" wx:for-item="member">
            <view class="member-avatar">
              <image class="avatar" src="{{member.avatarUrl || '../../images/avatar.png'}}" mode="aspectFill"></image>
              <text wx:if="{{member.openid === item.creatorOpenid}}" class="creator-badge">掌门人</text>
            </view>
            <view class="member-info">
              <view class="member-name-container">
                <text class="member-name">{{member.nickName.length > 6 ? member.nickName.substring(0, 6) + '...' : member.nickName}}</text>
              </view>
              <text class="member-role {{member.permission}}">{{member.permission === 'guardian' ? '一级助教' : member.permission === 'caretaker' ? '二级助教' : '围观吃瓜'}}</text>
            </view>
            <view class="member-actions">
              <button wx:if="{{currentUser.openid === item.creatorOpenid && member.openid !== item.creatorOpenid}}" class="action-btn edit-btn" bindtap="openPermissionModal" data-member="{{member}}" data-family-id="{{item._id}}">权限调整</button>
              <button wx:if="{{currentUser.openid === item.creatorOpenid && member.openid !== item.creatorOpenid}}" class="action-btn delete-btn" bindtap="removeMember" data-member="{{member}}" data-family-id="{{item._id}}">移除</button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 权限说明 -->
  <view class="permission-section">
    <text class="section-title">权限说明</text>
    <view class="permission-card">
      <view class="permission-item">
        <text class="permission-name creator">掌门人</text>
        <text class="permission-desc">家庭中最高权限</text>
      </view>
      <view class="permission-item">
        <text class="permission-name guardian">一级助教</text>
        <text class="permission-desc">可以新增和删除宝宝，可以新增和删除身高体重等数据</text>
      </view>
      <view class="permission-item">
        <text class="permission-name caretaker">二级助教</text>
        <text class="permission-desc">无法新增和删除宝宝，仅可以新增宝宝身高体重数据</text>
      </view>
      <view class="permission-item">
        <text class="permission-name viewer">围观吃瓜</text>
        <text class="permission-desc">只能查看宝宝数据</text>
      </view>
    </view>
  </view>
  
  <!-- 邀请成员弹窗 -->
  <view wx:if="{{showInviteModal}}" class="modal-overlay" bindtap="closeInviteModal">
    <view class="modal-content invite-modal" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">邀请成员</text>
        <text class="modal-subtitle">选择邀请的成员角色</text>
      </view>
      <view class="invite-options">
        <view
          wx:for="{{inviteRoleOptions}}"
          wx:key="type"
          class="invite-option-card {{item.cardClass}}"
          hover-class="invite-option-hover"
          bindtap="inviteMember"
          data-member-type="{{item.type}}"
        >
          <view class="card-content">
            <text class="role-title">{{item.title}}</text>
            <text class="role-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <button class="cancel-btn" bindtap="closeInviteModal">取消</button>
    </view>
  </view>

  <!-- 邀请码展示弹窗 -->
  <view wx:if="{{showInviteCodeModal}}" class="modal-overlay" bindtap="closeInviteCodeModal">
    <view class="modal-content invite-code-modal" catchtap="noop">
      <text class="modal-title">邀请成员</text>
      <text class="invite-code-label">请将此邀请码分享给家人</text>
      <view class="invite-code-display">
        <text class="invite-code-text">{{currentInviteCode}}</text>
      </view>
      <view class="invite-code-actions">
        <button class="action-btn copy-btn" bindtap="copyInviteCode">
          <text class="btn-text">复制</text>
        </button>
        <button class="action-btn share-btn" open-type="share" data-invite-code="{{currentInviteCode}}">
          <text class="btn-text">转发</text>
        </button>
      </view>
      <button class="cancel-btn" bindtap="closeInviteCodeModal">关闭</button>
    </view>
  </view>
  
  <!-- 修改权限弹窗 -->
  <view wx:if="{{showPermissionModal}}" class="modal-overlay" bindtap="closePermissionModal">
    <view class="modal-content" catchtap="noop">
      <text class="modal-title">修改权限</text>
      <view class="permission-options">
        <button class="permission-option-btn guardian-btn" bindtap="updatePermission" data-permission="guardian">一级助教</button>
        <button class="permission-option-btn caretaker-btn" bindtap="updatePermission" data-permission="caretaker">二级助教</button>
        <button class="permission-option-btn viewer-btn" bindtap="updatePermission" data-permission="viewer">围观吃瓜</button>
      </view>
      <button class="cancel-btn" bindtap="closePermissionModal">取消</button>
    </view>
  </view>
  
  <!-- 加入家庭弹窗 -->
  <view wx:if="{{showJoinModal}}" class="modal-overlay" bindtap="closeJoinModal">
    <view class="modal-content join-modal" catchtap="noop">
      <view class="join-modal-header">
        <text class="modal-title">加入家庭</text>
        <text class="modal-subtitle">输入邀请码加入家庭，与家人一起关注宝宝成长</text>
      </view>
      <view class="join-form">
        <view class="input-container">
          <text class="input-label">邀请码</text>
          <input class="invite-code-input" placeholder="请输入邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" />
          <text class="input-hint">邀请码由 8 位字母和数字组成</text>
        </view>
        <view class="form-actions">
          <button class="join-submit-btn" bindtap="submitJoinForm">
            <text class="btn-text">确认加入</text>
          </button>
          <button class="cancel-btn" bindtap="closeJoinModal">
            <text class="btn-text">取消</text>
          </button>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 新建家庭弹窗 -->
  <view wx:if="{{showCreateModal}}" class="modal-overlay" bindtap="closeCreateModal">
    <view class="modal-content join-modal" catchtap="noop">
      <view class="join-modal-header">
        <text class="modal-title">新建家庭</text>
        <text class="modal-subtitle">创建一个新家庭，与家人一起关注宝宝成长</text>
      </view>
      <view class="join-form">
        <view class="input-container">
          <text class="input-label">家庭名称</text>
          <input class="invite-code-input" placeholder="请输入家庭名称" value="{{familyName}}" bindinput="onFamilyNameInput" maxlength="7" />
          <text class="input-hint">家庭名称最多7个字符，每个用户最多只能创建一个家庭</text>
        </view>
        <view class="form-actions">
          <button class="join-submit-btn" bindtap="submitCreateForm">
            <text class="btn-text">创建家庭</text>
          </button>
          <button class="cancel-btn" bindtap="closeCreateModal">
            <text class="btn-text">取消</text>
          </button>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 修改家庭名称弹窗 -->
  <view wx:if="{{showEditNameModal}}" class="modal-overlay" bindtap="closeEditNameModal">
    <view class="modal-content join-modal" catchtap="noop">
      <view class="join-modal-header">
        <text class="modal-title">修改家庭名称</text>
        <text class="modal-subtitle">修改当前家庭的名称</text>
      </view>
      <view class="join-form">
        <view class="input-container">
          <text class="input-label">家庭名称</text>
          <input class="invite-code-input" placeholder="请输入家庭名称" value="{{editFamilyName}}" bindinput="onEditFamilyNameInput" maxlength="7" />
          <text class="input-hint">家庭名称最多7个字符</text>
        </view>
        <view class="form-actions">
          <button class="join-submit-btn" bindtap="submitEditNameForm">
            <text class="btn-text">保存</text>
          </button>
          <button class="cancel-btn" bindtap="closeEditNameModal">
            <text class="btn-text">取消</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 修改用户名弹窗 -->
  <view wx:if="{{showEditNicknameModal}}" class="modal-overlay" bindtap="closeEditNicknameModal">
    <view class="modal-content join-modal" catchtap="noop">
      <view class="join-modal-header">
        <text class="modal-title">修改用户名</text>
        <text class="modal-subtitle">修改您在家庭中显示的用户名</text>
      </view>
      <view class="join-form">
        <view class="input-container">
          <text class="input-label">用户名</text>
          <input class="invite-code-input" placeholder="请输入用户名" value="{{editNickname}}" bindinput="onEditNicknameInput" maxlength="7" />
          <text class="input-hint">用户名最多7个字符</text>
        </view>
        <view class="form-actions">
          <button class="join-submit-btn" bindtap="submitEditNicknameForm">
            <text class="btn-text">保存</text>
          </button>
          <button class="cancel-btn" bindtap="closeEditNicknameModal">
            <text class="btn-text">取消</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 反馈按钮 -->
  <view class="feedback-section">
    <button class="feedback-btn" bindtap="openFeedbackModal">
      <text class="btn-text">反馈问题</text>
    </button>
  </view>

  <!-- 反馈弹窗 -->
  <view wx:if="{{showFeedbackModal}}" class="modal-overlay" bindtap="closeFeedbackModal">
    <view class="modal-content feedback-modal" catchtap="noop">
      <!-- 头部区域 -->
      <view class="feedback-modal-header">
        <view class="feedback-icon-wrapper">
          <text class="feedback-icon">💬</text>
        </view>
        <text class="feedback-modal-title">反馈问题</text>
        <text class="feedback-modal-subtitle">请描述您遇到的问题或优化意见，我们会尽快处理</text>
      </view>

      <!-- 表单区域 -->
      <view class="feedback-form">
        <!-- 反馈内容输入 -->
        <view class="feedback-input-group">
          <view class="feedback-input-header">
            <text class="feedback-input-label">反馈内容</text>
            <text class="feedback-char-count">{{feedbackContent.length}}/500</text>
          </view>
          <view class="feedback-textarea-wrapper">
            <textarea
              class="feedback-textarea"
              placeholder="请详细描述您的问题或建议，我们会认真阅读每一条反馈..."
              placeholder-class="feedback-placeholder"
              value="{{feedbackContent}}"
              bindinput="onFeedbackContentInput"
              maxlength="500"
            />
          </view>
        </view>

        <!-- 图片上传 -->
        <view class="feedback-input-group">
          <view class="feedback-input-header">
            <text class="feedback-input-label">添加图片</text>
            <text class="feedback-input-optional">可选</text>
          </view>
          <view class="feedback-upload-wrapper">
            <view class="uploaded-images">
              <view wx:for="{{feedbackImages}}" wx:key="index" class="uploaded-image-item">
                <image src="{{item}}" mode="aspectFill" class="uploaded-image"></image>
                <view class="delete-image-btn" bindtap="deleteFeedbackImage" data-index="{{index}}">
                  <text class="delete-icon">×</text>
                </view>
              </view>
              <view wx:if="{{feedbackImages.length < 3}}" class="add-image-btn" bindtap="chooseFeedbackImage">
                <text class="add-icon">+</text>
                <text class="add-text">添加</text>
              </view>
            </view>
            <text class="feedback-upload-hint">最多可上传3张图片，支持 JPG、PNG 格式</text>
          </view>
        </view>

        <!-- 按钮区域 -->
        <view class="feedback-actions">
          <button class="feedback-cancel-btn" bindtap="closeFeedbackModal">
            <text class="btn-text">取消</text>
          </button>
          <button class="feedback-submit-btn" bindtap="submitFeedback">
            <text class="btn-text">提交反馈</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 掌门人退出确认弹窗 -->
  <view wx:if="{{showCreatorLeaveModal}}" class="modal-overlay" bindtap="closeCreatorLeaveModal">
    <view class="modal-content creator-leave-modal" catchtap="noop">
      <text class="modal-title">掌门人退出确认</text>
      <text class="modal-subtitle">您是该家庭掌门人，如果退出家庭，则由任意一级助理担任掌门人，请确定是否家庭中存在其他一级助理</text>
      <text wx:if="{{!hasOtherGuardians}}" class="modal-warning">当前家庭没有其他一级助理，无法退出，请先指定一级助理或选择解散家庭</text>
      <view class="creator-leave-actions">
        <button class="leave-action-btn cancel-btn" bindtap="closeCreatorLeaveModal">否</button>
        <button class="leave-action-btn confirm-btn {{hasOtherGuardians ? '' : 'disabled-btn'}}" bindtap="confirmLeaveFamily" disabled="{{!hasOtherGuardians}}">是</button>
        <button class="leave-action-btn danger-btn" bindtap="confirmDissolveFamily">解散家庭</button>
      </view>
    </view>
  </view>

  <!-- 解散家庭确认弹窗 -->
  <view wx:if="{{showDissolveConfirmModal}}" class="modal-overlay" bindtap="closeDissolveConfirmModal">
    <view class="modal-content dissolve-confirm-modal" catchtap="noop">
      <text class="modal-title">解散家庭确认</text>
      <text class="modal-subtitle danger-text">解散家庭将清除所有家庭和宝宝数据，无法恢复，请确认</text>
      <view class="dissolve-confirm-actions">
        <button class="leave-action-btn cancel-btn" bindtap="closeDissolveConfirmModal">取消</button>
        <button class="leave-action-btn danger-btn" bindtap="executeDissolveFamily">确认解散</button>
      </view>
    </view>
  </view>
</view>
