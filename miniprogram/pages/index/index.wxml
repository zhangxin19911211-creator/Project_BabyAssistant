<page-meta page-style=""></page-meta>
<!-- pages/index/index.wxml -->
<view class="container {{sortMode ? 'container-sort-mode' : ''}}">
  <view class="header">
    <view class="header-decoration"></view>
    <view class="title-area">
      <view class="icon-wrapper">
        <text class="main-icon">🌱</text>
      </view>
      <text class="title">萌芽季</text>
      <text class="subtitle" wx:if="{{babies.length > 0}}">我的宝宝（共 {{babies.length}} 位）</text>
      <text class="subtitle" wx:else>还没有宝宝，快去添加吧～</text>
    </view>
  </view>

  <view class="sort-toolbar" wx:if="{{babies.length > 1}}">
    <block wx:if="{{sortMode}}">
      <text class="sort-hint">拖动左侧手柄排序</text>
      <view class="sort-toolbar-spacer"></view>
      <button class="sort-btn sort-btn-done" hover-class="sort-btn-hover" bindtap="finishSortMode">完成</button>
    </block>
    <view wx:else class="sort-toolbar-btns">
      <button class="sort-btn sort-btn-compact" hover-class="sort-btn-hover" bindtap="enterSortMode">
        <view class="sort-btn-inner">自定义排序</view>
      </button>
      <button class="sort-btn sort-btn-compact sort-btn-age" hover-class="sort-btn-hover" bindtap="onAgeSortTap">
        <view class="sort-btn-inner">
          <text class="sort-btn-label">年龄排序</text>
          <text class="sort-age-arrow" wx:if="{{ageSortDirection === 'desc'}}">↓</text>
          <text class="sort-age-arrow" wx:elif="{{ageSortDirection === 'asc'}}">↑</text>
        </view>
      </button>
    </view>
  </view>

  <scroll-view
    id="sort-list"
    class="list-area {{sortMode ? 'list-area-sort-scroll' : ''}}"
    scroll-y="{{sortMode}}"
    enhanced="{{sortMode}}"
    show-scrollbar="{{sortMode}}"
    enable-flex="{{true}}"
  >
    <view class="empty-state" wx:if="{{babies.length === 0}}">
      <image class="empty-icon" src="../../images/baby-empty.svg" mode="aspectFit"></image>
      <text class="empty-text">还没有宝宝信息</text>
      <text class="empty-subtext">点击"添加宝宝"开始记录成长</text>
      <button class="add-first-btn" bindtap="goToAddBaby">🍼 添加宝宝</button>
    </view>

    <block wx:else>
      <view
        class="baby-card-wrap {{sortMode ? 'baby-card-wrap-sort' : ''}} {{sortDragBabyId === item._id ? 'baby-card-wrap-dragging' : ''}}"
        style="{{sortDragBabyId === item._id ? sortDragItemStyle : ''}}"
        wx:for="{{babies}}"
        wx:key="_id"
      >
        <view
          wx:if="{{sortMode}}"
          class="drag-handle"
          catchtouchstart="onSortTouchStart"
          catchtouchmove="onSortTouchMove"
          catchtouchend="onSortTouchEnd"
          catchtouchcancel="onSortTouchEnd"
          data-index="{{index}}"
        >
          <text class="drag-dots">⋮⋮</text>
        </view>
        <view class="baby-card family-color-{{item.familyColorIndex}} {{sortMode ? 'baby-card-sort' : ''}}" bindtap="onBabyCardTap" data-id="{{item._id}}">
        <view class="card-content">
          <image class="avatar" src="{{item.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
          <view class="baby-info">
            <view class="name-row">
              <text class="name">{{item.name}}</text>
              <text class="gender {{item.gender === 'male' ? 'male' : 'female'}}">{{item.gender === 'male' ? '♂' : '♀'}}</text>
            </view>
            <view class="family-tag">
              <text class="family-name">{{item.familyName}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">年龄：<text class="highlight">{{item.ageStr}}</text></text>
            </view>
            <view class="info-row" wx:if="{{item.latestRecord}}">
              <text class="info-label">身高：<text class="highlight">{{item.latestRecord.height}}</text> cm</text>
              <text class="info-label">体重：<text class="highlight">{{item.latestRecord.weight}}</text> kg</text>
            </view>
          </view>
          <view class="delete-btn" wx:if="{{!sortMode}}" catchtap="deleteBaby" data-id="{{item._id}}">
            <image class="delete-icon" src="data:image/svg+xml;base64,"></image>
          </view>
        </view>
        </view>
      </view>

      <view class="add-more-card" wx:if="{{canAddBaby && !sortMode}}" bindtap="goToAddBaby">
        <text class="plus-icon-large">+</text>
        <text>添加宝宝（还可添加 {{availableSlots}} 个）</text>
      </view>
    </block>
  </scroll-view>
</view>
