/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(180deg, var(--baby-primary-light) 0%, var(--baby-bg) 30%);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 50rpx 30rpx 70rpx;
  background: linear-gradient(135deg, var(--baby-card) 0%, var(--baby-primary-light) 50%, var(--baby-coral-light) 100%);
  color: var(--baby-text);
  border-bottom-left-radius: 50rpx;
  border-bottom-right-radius: 50rpx;
  margin: -30rpx -30rpx 40rpx -30rpx;
  box-shadow: 0 8rpx 30rpx var(--baby-shadow);
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(127, 209, 185, 0.1);
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, var(--baby-coral-light) 0%, transparent 70%);
  opacity: 0.6;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -40%;
  left: -10%;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, var(--baby-yellow-light) 0%, transparent 70%);
  opacity: 0.5;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.header-decoration::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--baby-blue) 0%, transparent 70%);
  opacity: 0.3;
  animation: float 6s ease-in-out infinite;
}

.header-decoration::after {
  content: '';
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--baby-yellow) 0%, transparent 70%);
  opacity: 0.2;
  animation: float 8s ease-in-out infinite reverse;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(180deg);
  }
}

.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--baby-primary-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(127, 209, 185, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.main-icon {
  font-size: 56rpx;
  line-height: 1;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--baby-primary-dark);
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx var(--baby-shadow);
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 30rpx;
  color: var(--baby-primary-dark);
  font-weight: 600;
  opacity: 0.95;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(127, 209, 185, 0.3);
}

.add-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--baby-card) 0%, #F5F5F5 100%);
  color: var(--baby-primary-dark);
  padding: 16rpx 30rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  box-shadow: 0 6rpx 20rpx rgba(127, 209, 185, 0.25);
  border: 2rpx solid var(--baby-primary);
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(127, 209, 185, 0.2);
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, rgba(127, 209, 185, 0.2) 100%);
}

.plus-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.list-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 60rpx;
}

.add-first-btn {
  background: linear-gradient(135deg, var(--baby-coral) 0%, #FF9A8B 100%);
  color: var(--baby-card);
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 28rpx rgba(255, 182, 163, 0.4);
  white-space: nowrap;
  min-width: 240rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.add-first-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 182, 163, 0.35);
}

.baby-card {
  background: 
    radial-gradient(ellipse 120% 80% at 10% 10%, rgba(255, 182, 163, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse 100% 100% at 90% 90%, rgba(127, 209, 185, 0.12) 0%, transparent 45%),
    radial-gradient(circle at 70% 20%, rgba(255, 218, 185, 0.1) 0%, transparent 30%),
    linear-gradient(145deg, #FFFCF8 0%, #F8FFFD 25%, #FFF8F5 50%, #F5FFFA 75%, #FFFAF8 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(127, 209, 185, 0.08),
    0 8rpx 40rpx rgba(255, 182, 163, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(127, 209, 185, 0.15);
  transition: all 0.3s ease;
}

/* 顶部装饰线 */
.baby-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, 
    var(--baby-coral) 0%, 
    var(--baby-primary) 35%, 
    var(--baby-yellow) 70%, 
    var(--baby-coral) 100%
  );
}

/* 右上角装饰圆 */
.baby-card::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(127, 209, 185, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* 左下角装饰 */
.baby-card .card-decoration {
  position: absolute;
  bottom: -20rpx;
  left: -20rpx;
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle, rgba(255, 182, 163, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* 统一宝宝卡片样式 - 覆盖所有家庭配色 */
.baby-card.family-color-0,
.baby-card.family-color-1,
.baby-card.family-color-2 {
  background: 
    radial-gradient(ellipse 120% 80% at 10% 10%, rgba(255, 182, 163, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse 100% 100% at 90% 90%, rgba(127, 209, 185, 0.12) 0%, transparent 45%),
    radial-gradient(circle at 70% 20%, rgba(255, 218, 185, 0.1) 0%, transparent 30%),
    linear-gradient(145deg, #FFFCF8 0%, #F8FFFD 25%, #FFF8F5 50%, #F5FFFA 75%, #FFFAF8 100%);
  border-color: rgba(127, 209, 185, 0.15);
  box-shadow: 
    0 4rpx 20rpx rgba(127, 209, 185, 0.08),
    0 8rpx 40rpx rgba(255, 182, 163, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.baby-card.family-color-0::before,
.baby-card.family-color-1::before,
.baby-card.family-color-2::before {
  background: linear-gradient(90deg, 
    var(--baby-coral) 0%, 
    var(--baby-primary) 35%, 
    var(--baby-yellow) 70%, 
    var(--baby-coral) 100%
  );
}

.card-content {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 8rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, var(--baby-card) 100%);
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(127, 209, 185, 0.3);
  flex-shrink: 0;
}

.baby-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 42rpx;
  font-weight: 800;
  background: linear-gradient(90deg, var(--baby-primary), var(--baby-primary-dark));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  flex-shrink: 0;
  font-family: '站酷庆科黄油体', 'ZCOOL QingKe HuangYou', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.gender {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gender.male {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  color: #1976D2;
  box-shadow: 0 2rpx 6rpx rgba(25, 118, 210, 0.2);
}

.gender.female {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
  color: #C2185B;
  box-shadow: 0 2rpx 6rpx rgba(194, 24, 91, 0.2);
}

.info-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  flex-wrap: wrap;
}

.info-label {
  font-size: 28rpx;
  color: var(--baby-text);
  font-weight: 500;
  line-height: 1.4;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.highlight {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--baby-primary-dark);
  flex-shrink: 0;
}

.family-tag {
  font-size: 24rpx;
  color: var(--baby-text-secondary);
  font-weight: 500;
  margin-top: 4rpx;
  display: inline-block;
  background: var(--baby-primary-light);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  align-self: flex-start;
}

.divider {
  display: none;
}

.delete-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(244, 67, 54, 0.08);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s ease;
  margin-left: 8rpx;
  margin-top: 8rpx;
}

.delete-btn:active {
  background: rgba(244, 67, 54, 0.15);
  transform: scale(0.95);
}

.delete-icon {
  width: 36rpx;
  height: 36rpx;
}

.add-more-card {
  border: 3rpx dashed var(--baby-primary);
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--baby-primary-dark);
  font-size: 30rpx;
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, rgba(127, 209, 185, 0.1) 100%);
  font-weight: 600;
  transition: all 0.3s ease;
  border-style: dashed;
}

.add-more-card:active {
  background: linear-gradient(135deg, var(--baby-coral-light) 0%, rgba(255, 166, 158, 0.2) 100%);
  color: var(--baby-coral);
  border-color: var(--baby-coral);
}

.plus-icon-large {
  font-size: 72rpx;
  color: var(--baby-primary);
  margin-bottom: 12rpx;
  line-height: 1;
  font-weight: 300;
}

.add-more-card:active .plus-icon-large {
  color: var(--baby-coral);
}
