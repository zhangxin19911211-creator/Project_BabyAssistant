/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  background-color: var(--bg-color);
}

.header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 50rpx 30rpx 70rpx;
  background: linear-gradient(180deg, #F1F8E9 0%, #C8E6C9 50%, #A5D6A7 100%);
  color: #2E7D32;
  border-bottom-left-radius: 50rpx;
  border-bottom-right-radius: 50rpx;
  margin: -30rpx -30rpx 40rpx -30rpx;
  box-shadow: 0 8rpx 30rpx rgba(129, 199, 132, 0.3);
  position: relative;
  overflow: hidden;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0.1) 100%);
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  left: -40rpx;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  top: 40rpx;
  right: -30rpx;
}

.circle-3 {
  width: 80rpx;
  height: 80rpx;
  bottom: 20rpx;
  left: 30%;
}

.leaf {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  opacity: 0.3;
}

.leaf::before {
  content: '🍃';
  font-size: 50rpx;
}

.leaf-1 {
  top: 30rpx;
  right: 60rpx;
  transform: rotate(45deg);
}

.leaf-2 {
  bottom: 40rpx;
  left: 50rpx;
  transform: rotate(-30deg);
}

.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8F5E9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(76, 175, 80, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.main-icon {
  font-size: 56rpx;
  line-height: 1;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #1B5E20;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #388E3C;
  font-weight: 600;
  opacity: 0.95;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.add-btn {
  display: flex;
  align-items: center;
  background-color: var(--primary-color);
  color: var(--white);
  padding: 16rpx 30rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  box-shadow: 0 6rpx 20rpx var(--primary-light);
}

.plus-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.list-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}

.emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 60rpx;
}

.add-first-btn {
  background-color: var(--primary-color);
  color: var(--white);
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 28rpx var(--primary-light);
  white-space: nowrap;
  min-width: 240rpx;
  text-align: center;
}

.baby-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F1F8E9 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(129, 199, 132, 0.15);
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(165, 214, 167, 0.3);
  transition: all 0.3s ease;
}

.baby-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #81C784 0%, #4CAF50 50%, #81C784 100%);
}

.card-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  margin-right: 24rpx;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(129, 199, 132, 0.25);
}

.baby-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 42rpx;
  font-weight: 800;
  color: #000000;
  margin-right: 14rpx;
  letter-spacing: 1rpx;
}

.gender {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.gender.male {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  color: #1976D2;
  box-shadow: 0 2rpx 6rpx rgba(25, 118, 210, 0.2);
}

.gender.female {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
  color: #C2185B;
  box-shadow: 0 2rpx 6rpx rgba(194, 24, 91, 0.2);
}

.info-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 28rpx;
  color: #000000;
  font-weight: 500;
  line-height: 1.4;
}

.highlight {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E7D32;
  margin: 0 2rpx;
}

.divider {
  display: none;
}

.delete-btn {
  padding: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(244, 67, 54, 0.08);
  border-radius: 50%;
  margin-left: 8rpx;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: rgba(244, 67, 54, 0.15);
  transform: scale(0.95);
}

.delete-icon {
  width: 36rpx;
  height: 36rpx;
}

.add-more-card {
  border: 3rpx dashed #A5D6A7;
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4CAF50;
  font-size: 30rpx;
  background: linear-gradient(135deg, rgba(241, 248, 233, 0.8) 0%, rgba(200, 230, 201, 0.6) 100%);
  font-weight: 600;
  transition: all 0.3s ease;
}

.add-more-card:active {
  background: linear-gradient(135deg, rgba(200, 230, 201, 0.9) 0%, rgba(165, 214, 167, 0.8) 100%);
}

.plus-icon-large {
  font-size: 72rpx;
  color: #4CAF50;
  margin-bottom: 12rpx;
  line-height: 1;
  font-weight: 300;
}
