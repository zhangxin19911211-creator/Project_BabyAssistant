<!--pages/baby-detail/baby-detail.wxml-->
<view class="container">
  <!-- Baby Info Header -->
  <view class="header-info">
    <view class="avatar-container" bindtap="chooseAvatar">
      <image class="avatar" src="{{baby.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
      <view class="avatar-edit-icon">+</view>
    </view>
    <view class="info">
      <text class="name" bindtap="onBabyNameTap">{{baby.name}}</text>
      <text class="age">{{baby.ageStr}}</text>
      <text class="family" wx:if="{{baby.familyName}}">所属家庭：{{baby.familyName}}</text>
    </view>
  </view>

  <!-- Top Navigation Tabs -->
  <view class="nav-tabs">
    <view class="tab {{currentTab === 'records' ? 'active' : ''}}" bindtap="switchTab" data-tab="records">记录列表</view>
    <view class="tab {{currentTab === 'height' ? 'active' : ''}}" bindtap="switchTab" data-tab="height">身高曲线</view>
    <view class="tab {{currentTab === 'weight' ? 'active' : ''}}" bindtap="switchTab" data-tab="weight">体重曲线</view>
  </view>

  <view class="action-bar" wx:if="{{currentTab === 'records'}}">
    <button class="add-btn" bindtap="goToAddRecord">+ 添加记录</button>
  </view>

  <!-- Content Area -->
  <view class="content-area">
    <!-- Records List -->
    <block wx:if="{{currentTab === 'records'}}">
      <view class="empty-state" wx:if="{{records.length === 0}}">
        <text class="empty-text">暂无成长记录</text>
      </view>
      
      <view class="record-list" wx:else>
        <view class="record-card" wx:for="{{records}}" wx:key="_id">
          <!-- 卡片头部：日期与年龄 -->
          <view class="record-header">
            <view class="record-date">
              <view class="date-dot"></view>
              <text class="date-text">{{item.formattedDate}}</text>
            </view>
            <view class="record-age">{{item.ageStr}}</view>
          </view>
          
          <!-- 核心数据区 -->
          <view class="record-body">
            <view class="data-item">
              <view class="data-icon height-icon">
                <text class="icon-text">↑</text>
              </view>
              <view class="data-content">
                <text class="data-label">身高</text>
                <view class="data-value-wrap">
                  <text class="data-value">{{item.height}}</text>
                  <text class="data-unit">cm</text>
                </view>
              </view>
            </view>
            
            <view class="data-divider"></view>
            
            <view class="data-item">
              <view class="data-icon weight-icon">
                <text class="icon-text">⚖</text>
              </view>
              <view class="data-content">
                <text class="data-label">体重</text>
                <view class="data-value-wrap">
                  <text class="data-value">{{item.weight}}</text>
                  <text class="data-unit">kg</text>
                </view>
              </view>
            </view>
            
            <view class="delete-btn" catchtap="deleteRecord" data-id="{{item._id}}">
              <text class="delete-icon">×</text>
              <text class="delete-text">删除</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- Height Curve -->
    <block wx:if="{{currentTab === 'height'}}">
      <view class="chart-container">
        <ec-canvas id="height-dom-line" canvas-id="height-line" ec="{{ ecHeight }}"></ec-canvas>
        <text class="chart-gesture-hint">双指捏合缩放，单指拖动平移</text>
      </view>
    </block>

    <!-- Weight Curve -->
    <block wx:if="{{currentTab === 'weight'}}">
      <view class="chart-container">
        <ec-canvas id="weight-dom-line" canvas-id="weight-line" ec="{{ ecWeight }}"></ec-canvas>
        <text class="chart-gesture-hint">双指捏合缩放，单指拖动平移</text>
      </view>
    </block>
  </view>

  <!-- 修改宝宝姓名弹窗 -->
  <view wx:if="{{showEditNameModal}}" class="modal-overlay" bindtap="closeEditNameModal">
    <view class="modal-content join-modal" catchtap="noop">
      <view class="join-modal-header">
        <text class="modal-title">修改宝宝姓名</text>
        <text class="modal-subtitle">修改宝宝的显示名称</text>
      </view>
      <view class="join-form">
        <view class="input-container">
          <text class="input-label">宝宝姓名</text>
          <input class="invite-code-input" placeholder="请输入宝宝姓名" value="{{editBabyName}}" bindinput="onEditBabyNameInput" maxlength="7" />
          <text class="input-hint">宝宝姓名最多7个字符</text>
        </view>
        <view class="form-actions">
          <button class="join-submit-btn" bindtap="submitEditNameForm">
            <text class="btn-text">保存</text>
          </button>
          <button class="cancel-btn" bindtap="closeEditNameModal">
            <text class="btn-text">取消</text>
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
