/* pages/baby-detail/baby-detail.wxss */
/* 柔和夏日风配色 - Call Me By Your Name */
page {
  /* 3 种家庭配色方案 - 柔和夏日风 */
  --family-color-0-primary: var(--cmbyn-color-1);
  --family-color-0-light: rgba(135, 206, 235, 0.1);
  --family-color-0-dark: var(--cmbyn-color-2);

  --family-color-1-primary: var(--cmbyn-color-4);
  --family-color-1-light: rgba(255, 160, 122, 0.1);
  --family-color-1-dark: #D4725C;

  --family-color-2-primary: var(--cat-color-2);
  --family-color-2-light: rgba(145, 204, 117, 0.1);
  --family-color-2-dark: #5A8A42;

  /* 角色配色 - 柔和协调版 */
  --guardian-color: #D65A5A;
  --guardian-bg: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
  --guardian-border: #F5C4C4;
  --caretaker-color: #5A8FC4;
  --caretaker-bg: linear-gradient(135deg, #F0F7FF 0%, #E0EFFF 100%);
  --caretaker-border: #B8D4F0;
  --viewer-color: #E89B5A;
  --viewer-bg: linear-gradient(135deg, #FFF8F0 0%, #FFECD8 100%);
  --viewer-border: #F5D4B8;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--baby-primary-light) 0%, var(--baby-bg) 30%);
  display: flex;
  flex-direction: column;
}

/* 头部信息区域 - 玻璃拟态效果 */
.header-info {
  display: flex;
  align-items: center;
  padding: 50rpx 40rpx;
  margin: 20rpx 30rpx 0;
  background: linear-gradient(135deg, var(--baby-card) 0%, var(--baby-primary-light) 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx var(--baby-shadow);
  position: relative;
  overflow: hidden;
}

.header-info::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, var(--baby-coral-light) 0%, transparent 70%);
  opacity: 0.6;
}

.avatar-container {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  border: 6rpx solid var(--baby-card);
  box-shadow: 0 8rpx 24rpx rgba(127, 209, 185, 0.3);
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--baby-coral) 0%, #FF9A8B 100%);
  color: var(--baby-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 182, 163, 0.4);
  border: 3rpx solid var(--baby-card);
}

.info {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.name {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--baby-text);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.age {
  font-size: 28rpx;
  color: var(--baby-text-secondary);
  background: rgba(127, 209, 185, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.family {
  font-size: 24rpx;
  color: var(--baby-primary-dark);
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, rgba(127, 209, 185, 0.1) 100%);
  padding: 6rpx 16rpx;
  border-radius: 18rpx;
  display: inline-block;
  border: 2rpx solid rgba(127, 209, 185, 0.2);
  font-weight: 500;
}

/* 导航标签 - 胶囊式设计 */
.nav-tabs {
  display: flex;
  background-color: var(--baby-card);
  margin: 30rpx;
  padding: 8rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--baby-text-secondary);
  position: relative;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.tab.active {
  color: var(--baby-card);
  font-weight: 600;
  background: linear-gradient(135deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  box-shadow: 0 4rpx 16rpx rgba(127, 209, 185, 0.4);
}

.action-bar {
  padding: 10rpx 30rpx 20rpx;
}

.add-btn {
  background: linear-gradient(135deg, var(--baby-coral) 0%, #FF9A8B 100%);
  color: var(--baby-card);
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: normal;
  box-shadow: 0 8rpx 24rpx rgba(255, 182, 163, 0.35);
  transition: transform 0.2s ease;
}

.add-btn:active {
  transform: scale(0.98);
}

.content-area {
  flex: 1;
  padding: 10rpx 30rpx 30rpx;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Records List */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  color: var(--baby-text-light);
  font-size: 30rpx;
}

.record-list {
  padding-bottom: 40rpx;
}

/* Record Card - 优化布局 */
.record-card {
  background: linear-gradient(135deg, var(--baby-card) 0%, rgba(255, 255, 255, 0.95) 100%);
  border-radius: 32rpx;
  padding: 0;
  margin-bottom: 28rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(102, 201, 168, 0.08),
    0 12rpx 40rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(127, 209, 185, 0.12);
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.record-card:active {
  transform: scale(0.995);
  box-shadow: 
    0 2rpx 12rpx rgba(102, 201, 168, 0.06),
    0 6rpx 20rpx rgba(0, 0, 0, 0.03);
}

/* Card Header - 日期与年龄 */
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, rgba(224, 245, 239, 0.5) 100%);
  border-bottom: 2rpx solid rgba(127, 209, 185, 0.1);
}

.record-date {
  display: flex;
  align-items: center;
}

.date-dot {
  width: 12rpx;
  height: 12rpx;
  background: linear-gradient(135deg, var(--baby-coral) 0%, #FF9A8B 100%);
  border-radius: 50%;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 182, 163, 0.4);
}

.date-text {
  font-size: 28rpx;
  color: var(--baby-text-secondary);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.record-age {
  background: linear-gradient(135deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  color: var(--baby-card);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(127, 209, 185, 0.3);
}

/* Card Body - 核心数据区 */
.record-body {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  gap: 20rpx;
}

.data-item {
  display: flex;
  align-items: center;
  flex: 1;
  max-width: 40%;
}

.data-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.height-icon {
  background: linear-gradient(135deg, var(--baby-primary-light) 0%, rgba(102, 201, 168, 0.2) 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 201, 168, 0.2);
}

.height-icon .icon-text {
  font-size: 32rpx;
  color: var(--baby-primary-dark);
  font-weight: bold;
}

.weight-icon {
  background: linear-gradient(135deg, var(--baby-coral-light) 0%, rgba(255, 182, 163, 0.2) 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 182, 163, 0.2);
}

.weight-icon .icon-text {
  font-size: 28rpx;
  color: #E57373;
  font-weight: bold;
}

.data-content {
  display: flex;
  flex-direction: column;
}

.data-label {
  font-size: 24rpx;
  color: var(--baby-text-light);
  margin-bottom: 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.data-value-wrap {
  display: flex;
  align-items: baseline;
}

.data-value {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--baby-text);
  line-height: 1;
  letter-spacing: -1rpx;
}

.data-unit {
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 8rpx;
  color: var(--baby-text-secondary);
}

.data-divider {
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(127, 209, 185, 0.3) 20%, rgba(127, 209, 185, 0.5) 50%, rgba(127, 209, 185, 0.3) 80%, transparent 100%);
  margin: 0 16rpx;
  border-radius: 2rpx;
  flex-shrink: 0;
}

.delete-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 139, 148, 0.08) 0%, rgba(255, 139, 148, 0.04) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 139, 148, 0.15);
  transition: all 0.2s ease;
  flex-shrink: 0;
  margin-left: auto;
}

.delete-btn:active {
  background: linear-gradient(135deg, rgba(255, 139, 148, 0.15) 0%, rgba(255, 139, 148, 0.08) 100%);
  border-color: rgba(255, 139, 148, 0.3);
  transform: scale(0.96);
}

.delete-icon {
  font-size: 24rpx;
  color: var(--baby-danger);
  margin-right: 6rpx;
  font-weight: 300;
  line-height: 1;
}

.delete-text {
  font-size: 22rpx;
  color: var(--baby-danger);
  font-weight: 500;
}

/* Charts - 新设计 */
.chart-container {
  width: 100%;
  flex: 1;
  min-height: 600rpx;
  background-color: var(--baby-card);
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  margin-top: 10rpx;
  position: relative;
  overflow: visible;
  border: 2rpx solid rgba(127, 209, 185, 0.1);
}

.legend {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--baby-primary-light);
}

.legend-item {
  display: flex;
  align-items: center;
  margin: 0 24rpx;
  font-size: 26rpx;
  color: var(--baby-text-secondary);
  font-weight: 500;
}

.color-box {
  width: 24rpx;
  height: 8rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.color-box.standard {
  background: linear-gradient(90deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
}

.color-box.actual {
  background: linear-gradient(90deg, var(--baby-coral) 0%, #FF9A8B 100%);
}

ec-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}
