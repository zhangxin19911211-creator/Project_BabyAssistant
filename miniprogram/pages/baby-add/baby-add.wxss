/* pages/baby-add/baby-add.wxss */
.container {
  padding: 30rpx;
  background-color: var(--white);
  min-height: 100vh;
}

.form-container {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 16rpx;
  display: block;
}

.input, .picker-view {
  width: 100%;
  height: 88rpx;
  background-color: var(--bg-color);
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: var(--text-main);
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.placeholder {
  color: var(--text-light);
}

.radio-group {
  display: flex;
  align-items: center;
  height: 88rpx;
}

.radio-label {
  margin-right: 60rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
}

.radio-label radio {
  transform: scale(0.8);
}

.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background-color: var(--white);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background-color: var(--primary-color);
  color: var(--white);
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx var(--primary-light);
}
