/* pages/baby-add/baby-add.wxss */
.container {
  padding: 30rpx;
  background: linear-gradient(180deg, var(--baby-primary-light) 0%, var(--baby-bg) 30%);
  min-height: 100vh;
}

.form-container {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--baby-text);
  margin-bottom: 16rpx;
  display: block;
}

.input, .picker-view {
  width: 100%;
  height: 88rpx;
  background-color: var(--baby-card);
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: var(--baby-text);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx var(--baby-shadow);
  border: 2rpx solid rgba(127, 209, 185, 0.1);
}

.placeholder {
  color: var(--baby-text-light);
}

.radio-group {
  display: flex;
  align-items: center;
  height: 88rpx;
  background-color: var(--baby-card);
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 12rpx var(--baby-shadow);
  border: 2rpx solid rgba(127, 209, 185, 0.1);
}

.radio-label {
  margin-right: 60rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: var(--baby-text);
}

.radio-label radio {
  transform: scale(0.8);
}

.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, var(--baby-card) 0%, var(--baby-primary-light) 100%);
  box-shadow: 0 -4rpx 16rpx var(--baby-shadow);
  border-top: 2rpx solid rgba(127, 209, 185, 0.1);
}

.submit-btn {
  background: linear-gradient(135deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  color: var(--baby-card);
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx var(--baby-shadow);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 12rpx var(--baby-shadow);
}
