/* pages/baby-add/baby-add.wxss */
/* 温暖活力的婴儿主题配色 */
page {
  --baby-primary: #66C9A8;
  --baby-primary-light: #E0F5EF;
  --baby-primary-dark: #4DB896;
  --baby-coral: #FFA69E;
  --baby-coral-light: #FFE8E6;
  --baby-yellow: #FFD166;
  --baby-yellow-light: #FFF8E1;
  --baby-blue: #64B5F6;
  --baby-blue-light: #E3F2FD;
  --baby-bg: #FDF5F0;
  --baby-card: #FFFFFF;
  --baby-text: #2D2D2D;
  --baby-text-secondary: #5B6270;
  --baby-text-light: #8C939F;
  --baby-success: #5BCB67;
  --baby-warning: #FFC107;
  --baby-danger: #FF7B84;
  --baby-shadow: rgba(102, 201, 168, 0.2);
  
  /* 角色配色 */
  --guardian-color: #C62828;
  --guardian-bg: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
  --guardian-border: #EF9A9A;
  --caretaker-color: #1565C0;
  --caretaker-bg: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  --caretaker-border: #90CAF9;
  --viewer-color: #E65100;
  --viewer-bg: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  --viewer-border: #FFB74D;
}

.container {
  padding: 30rpx;
  background: linear-gradient(180deg, var(--baby-primary-light) 0%, var(--baby-bg) 20%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面标题 */
.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--baby-text);
  margin-bottom: 12rpx;
  text-align: center;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--baby-text-secondary);
  text-align: center;
  margin-bottom: 50rpx;
}

.form-container {
  margin-top: 20rpx;
  background: var(--baby-card);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(127, 209, 185, 0.1);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--baby-text);
  margin-bottom: 16rpx;
  display: block;
  position: relative;
  padding-left: 20rpx;
}

.label::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: linear-gradient(180deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  border-radius: 3rpx;
}

.input, .picker-view {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--baby-bg) 0%, #FFFFFF 100%);
  border-radius: 20rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: var(--baby-text);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(127, 209, 185, 0.15);
  transition: all 0.3s ease;
}

.input:focus {
  border-color: var(--baby-primary);
  box-shadow: 0 0 0 4rpx rgba(127, 209, 185, 0.15);
}

.placeholder {
  color: var(--baby-text-light);
}

/* 性别选择 - 卡片式设计 */
.radio-group {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.radio-label {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--baby-bg);
  border-radius: 20rpx;
  font-size: 30rpx;
  color: var(--baby-text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.radio-label radio {
  transform: scale(0.8);
  margin-right: 12rpx;
}

.radio-label[checked] {
  background: var(--baby-primary-light);
  color: var(--baby-primary-dark);
  border-color: var(--baby-primary);
}

.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, var(--baby-card) 30%);
}

.submit-btn {
  background: linear-gradient(135deg, var(--baby-primary) 0%, var(--baby-primary-dark) 100%);
  color: var(--baby-card);
  border-radius: 48rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(127, 209, 185, 0.4);
  border: none;
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(127, 209, 185, 0.3);
}
